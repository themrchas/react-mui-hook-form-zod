import {
    Dialog,
    DialogContent,
    DialogActions,
    Button,
    Select,
    MenuItem,
    Stack,
    InputLabel
} from '@mui/material';

import { useState, useEffect } from 'react';
import { Controller, Control } from 'react-hook-form';

import { GenericAutocomplete } from './GenericAutocomplete';
import { TEST_PERSON } from '../../../constants/travelConstants';
import { LEAD_DIR } from '../../../constants/activityConstants';

import type { TravelFormValues } from '../Travel'; // adjust path if needed

type Props = {
    control: Control<TravelFormValues>;
    index: number | null;
    isOpen: boolean;
    append: (value: any) => void;
    setDialogIsOpen: (open: boolean) => void;
};

export const TravelWorksheetAddPerson = ({
    control,
    index,
    isOpen,
    append,
    setDialogIsOpen
}: Props) => {

    const isEditMode = index !== null;

    // Local state ONLY for create mode
    const [localOffice, setLocalOffice] = useState("");
    const [localPerson, setLocalPerson] = useState("");

    // Reset when dialog opens in create mode
    useEffect(() => {
        if (isOpen && !isEditMode) {
            setLocalOffice("");
            setLocalPerson("");
        }
    }, [isOpen, isEditMode]);

    const handleSave = () => {
        if (isEditMode) {
            // RHF already updated values
            setDialogIsOpen(false);
        } else {
            append({
                office: localOffice,
                person: localPerson,
                travelStart: null,
                travelEnd: null,
                travelModes: []
            });
            setDialogIsOpen(false);
        }
    };

    const handleCancel = () => {
        setDialogIsOpen(false);
    };

    if (!isOpen) return null;

    return (
        <Dialog open={isOpen} fullWidth maxWidth="sm">
            <DialogContent>
                <Stack spacing={2}>

                    {/* OFFICE */}
                    <InputLabel>Office</InputLabel>

                    {isEditMode ? (
                        <Controller
                            name={`travel.travelers.${index}.office`}
                            control={control}
                            render={({ field }) => (
                                <Select {...field}>
                                    {LEAD_DIR.map((dir, i) => (
                                        <MenuItem key={i} value={dir}>
                                            {dir}
                                        </MenuItem>
                                    ))}
                                </Select>
                            )}
                        />
                    ) : (
                        <Select
                            value={localOffice}
                            onChange={(e) => setLocalOffice(e.target.value)}
                        >
                            {LEAD_DIR.map((dir, i) => (
                                <MenuItem key={i} value={dir}>
                                    {dir}
                                </MenuItem>
                            ))}
                        </Select>
                    )}

                    {/* PERSON */}
                    {isEditMode ? (
                        <GenericAutocomplete<TravelFormValues, (typeof TEST_PERSON)[number]>
                            name={`travel.travelers.${index}.person`}
                            control={control}
                            options={TEST_PERSON}
                            getOptionLabel={(p) => p.label}
                            getOptionValue={(p) => p.label}
                        />
                    ) : (
                        <GenericAutocomplete<any, (typeof TEST_PERSON)[number]>
                            name={"_unused"} // not used in create mode
                            control={control} // not used but required by type
                            options={TEST_PERSON}
                            getOptionLabel={(p) => p.label}
                            getOptionValue={(p) => p.label}
                            value={localPerson}
                            onChange={setLocalPerson}
                        />
                    )}

                </Stack>
            </DialogContent>

            <DialogActions>
                <Button onClick={handleSave}>
                    {isEditMode ? "Save" : "Add"}
                </Button>
                <Button onClick={handleCancel}>Cancel</Button>
            </DialogActions>
        </Dialog>
    );
};